#!/usr/bin/env bash
set -euo pipefail

SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(cd "$(dirname "${SCRIPT_PATH}")" && pwd)"
KROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

cmd="${1:-}"
shift || true

case "${cmd}" in

memory)
    sub="${1:-}"
    shift || true
    case "${sub}" in
        add)
            python3 "${KROOT}/runtime/kao_memory.py" add "$*"
            ;;
        search)
            python3 "${KROOT}/runtime/kao_memory.py" search "$*"
            ;;
        recall)
            python3 "${KROOT}/runtime/kao_memory.py" recall "$1"
            ;;
        *)
            echo "usage: kao memory [add|search|recall]"
            ;;
    esac
    ;;

ask)
    exec "${KROOT}/bin/brain" infer "$@"
    ;;

status)
    exec "${KROOT}/bin/kao-status" "$@"
    ;;

*)
    echo "KAO CLI"
    ;;
esac
