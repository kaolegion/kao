#!/usr/bin/env bash
set -euo pipefail

SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(cd "$(dirname "${SCRIPT_PATH}")" && pwd)"
KROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

cmd="${1:-}"
shift || true

case "${cmd}" in

router)
    sub="${1:-status}"
    shift || true

    source "${KROOT}/lib/router/router_dispatch.sh"

    case "${sub}" in
        dispatch)
            router_dispatch "$@"
            ;;
        *)
            echo "usage: kao router dispatch <intent>"
printf '  kao pulse
printf '  kao cockpit
'
'    printf '  kao cockpit
'
            exit 1
            ;;
    esac
    ;;

health)
    exec "${KROOT}/bin/kao-health-cognitive" "$@"
    ;;

authority)
    exec "${KROOT}/bin/kao-authority" "$@"
    ;;

owner)
    exec "${KROOT}/bin/kao-owner" "$@"
    ;;

user)
    exec "${KROOT}/bin/kao-user" "$@"
    ;;

runtime)
    exec "${KROOT}/bin/kao-runtime" "$@"
    ;;

cockpit)

    exec "${KROOT}/bin/kao-cockpit" "$@"

    ;;

pulse)

    exec "${KROOT}/bin/kao-pulse" "$@"

    ;;

status)
    exec "${KROOT}/bin/kao-status" "$@"
    ;;

lock|transaction|consistency|session)
    exec "${KROOT}/bin/kao-runtime" "${cmd}" "$@"
    ;;

""|help|-h|--help)
    printf 'KAO CLI\n'
    printf '\n'
    printf 'usage:\n'
    printf '  kao status\n'
    printf '  kao runtime [status|refresh|snapshot|mode]\n'
    printf '  kao lock status\n'
    printf '  kao transaction status\n'
    printf '  kao consistency status\n'
    printf '  kao session status\n'
    printf '  kao health\n'
    printf '  kao owner\n'
    printf '  kao user\n'
    printf '  kao authority\n'
    printf '  kao router dispatch <intent>\n'
    printf '  kao pulse\n'
    printf '  kao cockpit\n'
    ;;
*)
    echo "KAO CLI"
    exit 1
    ;;

esac
