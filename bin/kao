#!/usr/bin/env bash
set -euo pipefail

SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(cd "$(dirname "${SCRIPT_PATH}")" && pwd)"
KROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

cmd="${1:-}"
shift || true

case "${cmd}" in

memory) python3 "${KROOT}/runtime/kao_memory.py" "$@" ;;
goal) python3 "${KROOT}/runtime/kao_goal.py" "$@" ;;
action) python3 "${KROOT}/runtime/kao_action.py" "$@" ;;
sense) python3 "${KROOT}/runtime/kao_sense.py" "$@" ;;
feedback) python3 "${KROOT}/runtime/kao_feedback.py" "$@" ;;
priority) python3 "${KROOT}/runtime/kao_priority.py" "$@" ;;
timeline) python3 "${KROOT}/runtime/kao_timeline.py" "$@" ;;
pulse) python3 "${KROOT}/runtime/kao_pulse.py" "$@" ;;
workspace) python3 "${KROOT}/runtime/kao_workspace.py" "$@" ;;
tools) python3 "${KROOT}/runtime/kao_tools.py" "$@" ;;

presence)
    sub="${1:-}"
    shift || true
    case "${sub}" in
        state) python3 "${KROOT}/runtime/kao_presence.py" state ;;
        *) python3 "${KROOT}/runtime/kao_presence.py" ;;
    esac
    ;;

stream)
    sub="${1:-}"
    shift || true
    case "${sub}" in
        state) python3 "${KROOT}/runtime/kao_stream.py" state ;;
        *) python3 "${KROOT}/runtime/kao_stream.py" ;;
    esac
    ;;

ask)
    exec "${KROOT}/bin/brain" infer "$@"
    ;;

status)
    exec "${KROOT}/bin/kao-status" "$@"
    ;;

*)
    echo "KAO CLI"
    ;;
esac
