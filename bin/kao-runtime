#!/usr/bin/env bash
set -euo pipefail

SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(cd "$(dirname "${SCRIPT_PATH}")" && pwd)"
KROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

cmd="${1:-}"
shift || true

case "${cmd}" in

session)

    sub="${1:-status}"
    shift || true

    . "${KROOT}/lib/runtime/session_manager.sh"
    . "${KROOT}/lib/runtime/session_memory_recall.sh"
    . "${KROOT}/lib/runtime/session_history_engine.sh"
    . "${KROOT}/lib/runtime/session_stats_engine.sh"
    . "${KROOT}/lib/runtime/session_insight_engine.sh"

    case "${sub}" in

        open)
            kao_session_open
            ;;

        close)
            kao_session_close
            ;;

        status)
            . "${KROOT}/lib/runtime/session_cognitive_state.sh"
            kao_session_cognitive_state
            ;;

        recall)
            kao_session_memory_recall "$@"
            ;;

        summary)
            kao_session_memory_recall --summary
            ;;

        history)
            kao_session_phase_history
            ;;

        stats)
            kao_session_phase_stats
            ;;

        insight)
            kao_session_behavior_insight
            ;;

        *)
            echo "usage:"
            echo "  kao session open"
            echo "  kao session close"
            echo "  kao session status"
            echo "  kao session recall"
            echo "  kao session summary"
            echo "  kao session history"
            echo "  kao session stats"
            echo "  kao session insight"
            exit 1
            ;;

    esac
    ;;

*)
    exec "${KROOT}/bin/kao" "${cmd}" "$@"
    ;;

esac
