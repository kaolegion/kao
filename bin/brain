#!/usr/bin/env bash
set -euo pipefail

# REKON-CANONICAL-CANDIDATE: current cognitive orchestration entrypoint.
# TODO(REKON): extract infer pipeline into explicit named stages once runtime canon is declared.
# TODO(REKON-TEST): preserve resolution order task_attach -> mission_gate -> self_answer -> self_llm_context -> gateway_infer.

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
KROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

ROUTER_LIB="${KROOT}/lib/gateway/router.sh"
SELF_LOOP_LIB="${KROOT}/lib/cognition/kao_self_loop.sh"
AGENT_CONTEXT_LIB="${KROOT}/lib/agents/context_builder.sh"
AGENT_MISSION_LIB="${KROOT}/lib/agents/mission_kernel.sh"

if [ ! -f "${ROUTER_LIB}" ]; then
  printf 'BRAIN_ERROR gateway router missing: %s\n' "${ROUTER_LIB}" >&2
  exit 1
fi

. "${ROUTER_LIB}"
[ -f "${SELF_LOOP_LIB}" ] && . "${SELF_LOOP_LIB}"
[ -f "${AGENT_CONTEXT_LIB}" ] && . "${AGENT_CONTEXT_LIB}"
[ -f "${AGENT_MISSION_LIB}" ] && . "${AGENT_MISSION_LIB}"

brain_usage() {
  printf 'Usage:\n'
  printf '  brain infer "<query>"\n'
}

mode="${1:-help}"

case "${mode}" in
  infer)
    shift || true
    if [ "$#" -eq 0 ]; then
      printf 'BRAIN_ERROR missing query\n' >&2
      brain_usage >&2
      exit 1
    fi

    query="$*"

    if declare -F kao_agent_task_attach >/dev/null 2>&1; then
      kao_agent_task_attach
    fi

    if declare -F kao_mission_gate_handle >/dev/null 2>&1; then
      if kao_mission_gate_handle "${query}"; then
        exit 0
      fi
    fi

    if declare -F kao_self_can_answer >/dev/null 2>&1; then
      if kao_self_can_answer "${query}"; then
        kao_self_answer "${query}"
        exit 0
      fi
    fi

    if declare -F kao_self_llm_context_build >/dev/null 2>&1; then
      context="$(kao_self_llm_context_build "${query}")"
      gateway_infer "${context}"
      exit 0
    fi

    if declare -F kao_agent_context_build >/dev/null 2>&1; then
      context="$(kao_agent_context_build)"
      gateway_infer "${context}${query}"
    else
      gateway_infer "${query}"
    fi
    ;;
  help|-h|--help)
    brain_usage
    ;;
  *)
    printf 'BRAIN_ERROR unknown mode: %s\n' "${mode}" >&2
    brain_usage >&2
    exit 1
    ;;
esac
