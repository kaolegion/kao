#!/usr/bin/env bash
set -euo pipefail

# REKON-CANONICAL-CANDIDATE: cognitive orchestration entrypoint with explicit sovereign memory-first path.
# TODO(SENTINEL): ensure router-core remains side-effect free and memory-first stays prior to provider arbitration.
# TODO(SYFER): maintain clear boundary self-answer -> router-core -> gateway.
# TODO(REKON-TEST): preserve truthful sovereign self-answer before any provider call when local cognition is sufficient.

SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(cd "$(dirname "${SCRIPT_PATH}")" && pwd)"
KROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

ROUTER_LIB="${KROOT}/lib/gateway/router.sh"
ROUTER_CORE_LIB="${KROOT}/lib/router/router_core_contract.sh"
MISSION_LIB="${KROOT}/lib/agents/mission_kernel.sh"
SELF_LOOP_LIB="${KROOT}/lib/cognition/kao_self_loop.sh"

[ -f "${ROUTER_LIB}" ] || {
  printf 'BRAIN_ERROR gateway router missing: %s\n' "${ROUTER_LIB}" >&2
  exit 66
}

# shellcheck disable=SC1090
source "${ROUTER_LIB}"

[ -f "${ROUTER_CORE_LIB}" ] && source "${ROUTER_CORE_LIB}"
[ -f "${MISSION_LIB}" ] && source "${MISSION_LIB}"
[ -f "${SELF_LOOP_LIB}" ] && source "${SELF_LOOP_LIB}"

brain_usage() {
  printf 'BRAIN\n'
  printf 'Usage:\n'
  printf '  brain infer "<query>"\n'
}

brain_hotpath_log() {
  local stage detail
  stage="${1:-UNKNOWN}"
  detail="${2:-none}"
  printf '[KAO][BRAIN][%s] %s\n' "${stage}" "${detail}"
}

brain_hot_path_handle() {
  local query="${1:-}"

  if declare -F kao_mission_gate_handle >/dev/null 2>&1; then
    if kao_mission_gate_handle "${query}"; then
      brain_hotpath_log "MISSION_GATE" "opened"
      return 0
    fi
  fi

  return 1
}

brain_infer() {
  local query context self_answered=0

  query="${*:-}"
  if [ -z "${query}" ]; then
    printf 'BRAIN_ERROR missing query\n' >&2
    return 64
  fi

  if declare -F kao_agent_task_attach >/dev/null 2>&1; then
    kao_agent_task_attach
  fi

  if brain_hot_path_handle "${query}"; then
    return 0
  fi

  if declare -F kao_self_can_answer >/dev/null 2>&1; then
    if kao_self_can_answer "${query}"; then
      brain_hotpath_log "SELF_ANSWER" "memory-first"
      kao_self_answer "${query}"
      self_answered=1
    fi
  fi

  if [ "${self_answered}" -eq 1 ]; then
    return 0
  fi

  context=""
  if declare -F kao_self_llm_context_build >/dev/null 2>&1; then
    context="$(kao_self_llm_context_build "${query}")"
  fi

  if declare -F router_core_contract_build >/dev/null 2>&1; then
    router_core_contract_build "${query}"
  fi

  if [ -n "${context}" ]; then
    brain_hotpath_log "LLM_ARBITRATION" "gateway-context"
    gateway_infer "${context}${query}"
  else
    brain_hotpath_log "LLM_ARBITRATION" "raw-query-fallback"
    gateway_infer "${query}"
  fi
}

case "${1:-}" in
  infer)
    shift
    brain_infer "$@"
    ;;
  ""|-h|--help|help)
    brain_usage
    ;;
  *)
    printf 'BRAIN_ERROR unknown command: %s\n' "${1:-}" >&2
    exit 64
    ;;
esac
