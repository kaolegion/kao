#!/usr/bin/env bash

KROOT="${KROOT:-/home/kao}"
TIMELINE="${KROOT}/state/runtime/session.timeline"
STATE_DIR="${KROOT}/state/router"
STATE_FILE="${STATE_DIR}/heat.daemon.state"
SEEN_FILE="${STATE_DIR}/heat.daemon.seen"

source "${KROOT}/lib/router/router_heat_engine.sh"

router_heat_daemon_init() {
    mkdir -p "${STATE_DIR}"

    if [ ! -f "${STATE_FILE}" ]; then
        cat <<'EOF_STATE' > "${STATE_FILE}"
LAST_TS=
LAST_PROVIDER=
EOF_STATE
    fi

    touch "${SEEN_FILE}"
}

router_heat_daemon_state_get() {
    grep "^$1=" "${STATE_FILE}" 2>/dev/null | cut -d= -f2-
}

router_heat_daemon_state_set() {
    local key="$1"
    local value="$2"
    local tmp
    tmp="$(mktemp)"
    grep -v "^${key}=" "${STATE_FILE}" 2>/dev/null > "${tmp}" || true
    printf '%s=%s\n' "${key}" "${value}" >> "${tmp}"
    mv "${tmp}" "${STATE_FILE}"
}

router_heat_daemon_extract_field() {
    local line="$1"
    local field="$2"
    printf '%s\n' "${line}" | tr '|' '\n' | grep "^${field}=" | tail -n 1 | cut -d= -f2-
}

router_heat_daemon_event_key() {
    local line="$1"
    local ts provider
    ts="$(router_heat_daemon_extract_field "${line}" "ts")"
    provider="$(router_heat_daemon_extract_field "${line}" "selected_provider")"

    [ -z "${ts}" ] && return 1
    [ -z "${provider}" ] && return 1
    [ "${provider}" = "unknown" ] && return 1

    printf '%s|%s\n' "${ts}" "${provider}"
}

router_heat_daemon_seen_has() {
    local key="$1"
    grep -Fxq "${key}" "${SEEN_FILE}" 2>/dev/null
}

router_heat_daemon_seen_add() {
    local key="$1"
    router_heat_daemon_seen_has "${key}" || printf '%s\n' "${key}" >> "${SEEN_FILE}"
}

router_heat_daemon_process_line() {
    local line="$1"
    local ts provider key last_provider

    ts="$(router_heat_daemon_extract_field "${line}" "ts")"
    provider="$(router_heat_daemon_extract_field "${line}" "selected_provider")"
    key="$(router_heat_daemon_event_key "${line}")" || return 0

    if router_heat_daemon_seen_has "${key}"; then
        return 0
    fi

    last_provider="$(router_heat_daemon_state_get LAST_PROVIDER)"

    if [ "${provider}" != "${last_provider}" ]; then
        router_heat_add_event "${provider}" || return 1
        echo "[heat] cognitive switch -> ${provider}"
    fi

    router_heat_daemon_state_set LAST_TS "${ts}"
    router_heat_daemon_state_set LAST_PROVIDER "${provider}"
    router_heat_daemon_seen_add "${key}"
}

router_heat_daemon_run_once() {
    local line
    [ -f "${TIMELINE}" ] || return 0

    while IFS= read -r line; do
        printf '%s\n' "${line}" | grep -q 'event_type=router-dispatch' || continue
        router_heat_daemon_process_line "${line}"
    done < <(tail -n 50 "${TIMELINE}" 2>/dev/null)
}

router_heat_daemon_init
echo "[heat-daemon] started"

while true; do
    router_heat_daemon_run_once
    sleep 2
done
