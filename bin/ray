#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
KROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# shellcheck disable=SC1091
. "${KROOT}/lib/gateway/router.sh"
# shellcheck disable=SC1091
. "${KROOT}/lib/cognition/intent_router.sh"
# shellcheck disable=SC1091
. "${KROOT}/lib/cognition/execution_bridge.sh"

ray_usage() {
  cat <<'USAGE'
USAGE: ray [status|registry|scout|ask "<prompt>"|bridge "<prompt>"|run "<prompt>"]

COMMANDS
  ray                     show ray hybrid status
  ray status              show ray hybrid status
  ray registry            show live model registry reading
  ray scout               show strategic live model landscape reading
  ray ask "<prompt>"      classify operator intent and show route family
  ray bridge "<prompt>"   show intent-aware execution bridge reading
  ray run "<prompt>"      run a prompt through the execution bridge
  ray "<prompt>"          shortcut for ray run "<prompt>"
USAGE
}

ray_status() {
  local selected_provider selected_label selected_kind selected_health selected_note
  local selected_route decision_state cloud_readiness local_readiness hybrid_state operator_mode
  local route_reason route_score cloud_score local_score
  local detected_provider forced_raw_value forced_provider forced_state
  local ollama_model ollama_model_state ollama_runtime ollama_real_calls ollama_real_state
  local registry_count registry_selected_provider registry_selected_model registry_selected_family
  local registry_selected_base registry_selected_declared registry_selected_runtime registry_selected_score
  local registry_selected_rank registry_selected_maturity

  selected_provider="$(gateway_provider_select)"
  selected_label="$(gateway_provider_label "${selected_provider}")"
  selected_kind="$(gateway_provider_kind "${selected_provider}")"
  selected_health="$(gateway_provider_health "${selected_provider}")"
  selected_note="$(gateway_provider_note "${selected_provider}")"

  selected_route="$(gateway_selected_route)"
  decision_state="$(gateway_decision_state)"
  cloud_readiness="$(gateway_cloud_readiness)"
  local_readiness="$(gateway_local_readiness)"
  hybrid_state="$(gateway_hybrid_state)"
  operator_mode="$(gateway_operator_mode)"
  route_reason="$(gateway_route_reason)"
  route_score="$(gateway_route_score)"
  cloud_score="$(gateway_cloud_score)"
  local_score="$(gateway_local_score)"

  detected_provider="$(gateway_provider_detected)"
  forced_raw_value="$(gateway_forced_provider_raw)"
  forced_provider="$(gateway_forced_provider)"
  forced_state="$(gateway_forced_provider_state)"

  ollama_model="$(gateway_ollama_model)"
  ollama_model_state="$(gateway_ollama_model_state)"
  ollama_runtime="$(gateway_ollama_runtime_state)"
  ollama_real_calls="$(gateway_ollama_real_calls_policy)"
  ollama_real_state="$(gateway_ollama_real_state)"

  registry_count="$(gateway_model_registry_count)"
  registry_selected_provider="$(gateway_model_registry_selected_provider)"
  registry_selected_model="$(gateway_model_registry_selected_model)"
  registry_selected_family="$(gateway_model_registry_selected_family)"
  registry_selected_base="$(gateway_model_registry_selected_base_score)"
  registry_selected_declared="$(gateway_model_registry_selected_declared_state)"
  registry_selected_runtime="$(gateway_model_registry_selected_runtime_state)"
  registry_selected_score="$(gateway_model_registry_selected_runtime_score)"
  registry_selected_rank="$(gateway_model_registry_selected_operator_rank_score)"
  registry_selected_maturity="$(gateway_model_registry_selected_maturity_level)"

  printf 'RAY STATUS\n'
  printf 'selected route    : %s\n' "${selected_route}"
  printf 'selected provider : %s\n' "${selected_provider}"
  printf 'selected label    : %s\n' "${selected_label}"
  printf 'selected kind     : %s\n' "${selected_kind}"
  printf 'selected health   : %s\n' "${selected_health}"
  printf 'selected note     : %s\n' "${selected_note}"
  printf 'decision state    : %s\n' "${decision_state}"
  printf 'route reason      : %s\n' "${route_reason}"
  printf 'route score       : %s\n' "${route_score}"
  printf 'cloud score       : %s\n' "${cloud_score}"
  printf 'local score       : %s\n' "${local_score}"
  printf 'mode              : %s\n' "${operator_mode}"
  printf 'hybrid state      : %s\n' "${hybrid_state}"
  printf 'cloud readiness   : %s\n' "${cloud_readiness}"
  printf 'local readiness   : %s\n' "${local_readiness}"
  printf 'forced raw value  : %s\n' "${forced_raw_value}"
  printf 'forced provider   : %s\n' "${forced_provider}"
  printf 'forced state      : %s\n' "${forced_state}"
  printf 'detected provider : %s\n' "${detected_provider}"
  printf 'registry count    : %s\n' "${registry_count}"
  printf 'registry provider : %s\n' "${registry_selected_provider}"
  printf 'registry model    : %s\n' "${registry_selected_model}"
  printf 'registry family   : %s\n' "${registry_selected_family}"
  printf 'registry base     : %s\n' "${registry_selected_base}"
  printf 'registry declared : %s\n' "${registry_selected_declared}"
  printf 'registry runtime  : %s\n' "${registry_selected_runtime}"
  printf 'registry score    : %s\n' "${registry_selected_score}"
  printf 'registry rank     : %s\n' "${registry_selected_rank}"
  printf 'registry maturity : %s\n' "${registry_selected_maturity}"
  printf 'ollama model      : %s\n' "${ollama_model}"
  printf 'ollama model state: %s\n' "${ollama_model_state}"
  printf 'ollama runtime    : %s\n' "${ollama_runtime}"
  printf 'ollama real calls : %s\n' "${ollama_real_calls}"
  printf 'ollama real state : %s\n' "${ollama_real_state}"
}

ray_registry() {
  gateway_model_registry_operator_surface
}

ray_scout_entry_line() {
  local provider model family maturity rank status

  provider="${1:-none}"

  model="$(gateway_registry_model_impl "${provider}")"
  family="$(gateway_registry_family_impl "${provider}")"
  maturity="$(gateway_registry_maturity_level_impl "${provider}")"
  rank="$(gateway_registry_operator_rank_score_impl "${provider}")"
  status="$(gateway_model_registry_strategic_status "${provider}" "${maturity}")"

  printf '%s | %s | family %s | maturity %s | rank %s | status %s\n' \
    "${provider}" \
    "${model}" \
    "${family}" \
    "${maturity}" \
    "${rank}" \
    "${status}"
}

ray_scout() {
  local ranked_dump provider

  gateway_require_model_registry

  printf 'MODEL LANDSCAPE\n\n'

  ranked_dump="$(gateway_registry_ranked_dump_impl)"
  if [ -z "${ranked_dump}" ]; then
    printf 'none\n'
    return 0
  fi

  while IFS='|' read -r provider _rest; do
    [ -n "${provider}" ] || continue
    ray_scout_entry_line "${provider}"
  done <<SCOUT_EOF
${ranked_dump}
SCOUT_EOF
}

ray_ask() {
  local prompt intent route action selected_provider
  local strategy surface execution_mode decision

  if [ "$#" -eq 0 ]; then
    printf 'RAY_ERROR missing prompt\n' >&2
    ray_usage >&2
    return 1
  fi

  prompt="$*"
  intent="$(intent_classify "${prompt}")"
  route="$(intent_route_family "${intent}")"
  action="$(intent_action_label "${intent}")"
  execution_mode="$(execution_mode_resolve)"
  strategy="$(execution_strategy_for_intent "${intent}")"
  surface="$(execution_surface_for_strategy "${strategy}")"
  decision="$(execution_decision_label "${strategy}" "${surface}")"

  printf 'RAY ASK\n'
  printf 'prompt  : %s\n' "${prompt}"
  printf 'INTENT  : %s\n' "${intent}"
  printf 'ROUTE   : %s\n' "${route}"
  printf 'ACTION  : %s\n' "${action}"
  printf 'MODE    : %s\n' "${execution_mode}"
  printf 'STRATEGY: %s\n' "${strategy}"
  printf 'SURFACE : %s\n' "${surface}"
  printf 'DECISION: %s\n' "${decision}"

  case "${route}" in
    llm-light|llm-heavy)
      selected_provider="$(gateway_provider_select)"
      printf 'PROVIDER: %s\n' "${selected_provider}"
      ;;
    *)
      printf 'PROVIDER: none\n'
      ;;
  esac
}

ray_bridge() {
  if [ "$#" -eq 0 ]; then
    printf 'RAY_ERROR missing prompt\n' >&2
    ray_usage >&2
    return 1
  fi

  execution_bridge_operator_surface "$@"
}

ray_run_gateway() {
  local prompt
  prompt="${*:-}"
  exec "${KROOT}/bin/brain" infer "${prompt}"
}

ray_run_local() {
  local prompt
  prompt="${*:-}"

  printf 'RAY RUN\n'
  execution_bridge_operator_surface "${prompt}"
  printf '\n'
  execution_bridge_execute_prompt "${prompt}"
}

ray_run() {
  local prompt intent strategy surface

  if [ "$#" -eq 0 ]; then
    printf 'RAY_ERROR missing prompt\n' >&2
    ray_usage >&2
    return 1
  fi

  prompt="$*"
  intent="$(intent_classify "${prompt}")"
  strategy="$(execution_strategy_for_intent "${intent}")"
  surface="$(execution_surface_for_strategy "${strategy}")"

  case "${surface}" in
    gateway)
      ray_run_gateway "${prompt}"
      ;;
    shell|system)
      ray_run_local "${prompt}"
      ;;
    *)
      printf 'RAY_ERROR unsupported execution bridge\n' >&2
      return 1
      ;;
  esac
}

main() {
  local command

  if [ "$#" -eq 0 ]; then
    ray_status
    return 0
  fi

  command="${1:-}"
  case "${command}" in
    status)
      shift
      ray_status "$@"
      ;;
    registry)
      shift
      ray_registry "$@"
      ;;
    scout)
      shift
      ray_scout "$@"
      ;;
    ask)
      shift
      ray_ask "$@"
      ;;
    bridge)
      shift
      ray_bridge "$@"
      ;;
    run)
      shift
      ray_run "$@"
      ;;
    -h|--help|help)
      ray_usage
      ;;
    *)
      ray_run "$@"
      ;;
  esac
}

main "$@"
