#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
KROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

ROUTER_LIB="${KROOT}/lib/gateway/router.sh"

echo "KAO ENVIRONMENT"
echo "----------------"

host="$(hostname)"

if grep -qi microsoft /proc/version 2>/dev/null; then
    os="Linux (WSL)"
else
    os="$(uname -s)"
fi

kernel="$(uname -r)"

if ping -c1 -W1 8.8.8.8 >/dev/null 2>&1; then
    network="online"
else
    network="offline"
fi

provider="unknown"
detected="unknown"
health="unknown"

if [ -f "${ROUTER_LIB}" ]; then
    # shellcheck disable=SC1090
    . "${ROUTER_LIB}"

    provider="$(gateway_provider_select || echo unknown)"
    detected="$(gateway_provider_detected || echo unknown)"
    health="$(gateway_provider_health "${provider}" || echo unknown)"
fi

echo "host        : $host"
echo "os          : $os"
echo "kernel      : $kernel"
echo "network     : $network"
echo "provider    : $provider"
echo "detected    : $detected"
echo "health      : $health"
echo "runtime     : cognitive-v0"
