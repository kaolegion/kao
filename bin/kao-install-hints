#!/usr/bin/env bash
set -Eeuo pipefail

file="${HOME}/config/dependencies.tsv"

if [ ! -f "${file}" ]; then
  printf '[FAIL] missing dependency policy file: %s\n' "${file}"
  exit 1
fi

printf '===== INSTALL HINTS =====\n'

while IFS=$'\t' read -r name class manager package required; do
  [ "$name" = "name" ] && continue
  [ -z "$name" ] && continue

  if ! command -v "$name" >/dev/null 2>&1; then
    case "$manager" in
      apt)
        printf '%-10s -> sudo apt install -y %s\n' "$name" "$package"
        ;;
      *)
        printf '%-10s -> no manager hint available\n' "$name"
        ;;
    esac
  fi
done < "$file"
